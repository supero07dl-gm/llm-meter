[Unit]
Description=LLM Meter Prometheus exporter
After=network.target llm-meter-ingest.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/llm-meter
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/local/bin/llm-meter export-prometheus --db /var/lib/llm-meter/llm-meter.db --host 127.0.0.1 --port 9108
Restart=always
RestartSec=5

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/llm-meter

[Install]
WantedBy=multi-user.target
